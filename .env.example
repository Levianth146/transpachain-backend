PORT=3001
MONGODB_URI=mongodb://localhost:27017/transpachain
# Primary Sepolia RPC (Alchemy, Infura, or public endpoint)
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Optional aliases / fallback when primary is rate-limited, paused, or times out
SEPOLIA_RPC_URL=
# Strongly recommended in production — used by health checks, backfill, and indexer when primary fails
SEPOLIA_RPC_FALLBACK_URL=https://rpc.sepolia.org
INFURA_SEPOLIA_URL=
# Health on-chain read timeout (ms); increase if primary RPC is slow without fallback
HEALTH_CHECK_TIMEOUT_MS=8000
CHARITY_CORE_ADDRESS=0xA13344e56a2421322bb2985ffE37b07DB80B760d
DONATION_VAULT_ADDRESS=0x72116A0BCe20473FE1BfcC2da9D2337A6D39Ed5c
GOVERNANCE_DAO_ADDRESS=0x290770c85B42c3a32365f6f6350587878dCbe2D5
IMPACT_NFT_ADDRESS=0x17CcdcF683626B5c914640154464bF64Ca66DB18
# Set to deploy block for first sync; set 0 after backfill completes to skip re-scanning
DEPLOY_FROM_BLOCK=11046235
# Indexer tuning (Alchemy free tier: keep chunk size low)
INDEXER_LOG_CHUNK_SIZE=10
INDEXER_CHUNK_DELAY_MS=300
INDEXER_POLL_INTERVAL_MS=15000
PINATA_API_KEY=YOUR_PINATA_KEY
PINATA_SECRET_KEY=YOUR_PINATA_SECRET
CORS_ORIGIN=http://localhost:3000
