PORT=3001
MONGODB_URI=mongodb://localhost:27017/transpachain
# Primary Sepolia RPC (Alchemy, Infura, or public endpoint)
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Optional aliases / fallback when primary is rate-limited, paused, or times out
SEPOLIA_RPC_URL=
# Strongly recommended in production — used by health checks, backfill, and indexer when primary fails
SEPOLIA_RPC_FALLBACK_URL=https://rpc.sepolia.org
INFURA_SEPOLIA_URL=
# Health on-chain read timeout (ms); increase if primary RPC is slow without fallback
HEALTH_CHECK_TIMEOUT_MS=8000
CHARITY_CORE_ADDRESS=0xCE017838BfE2785CB2458bb205770663bEB9b0B8
DONATION_VAULT_ADDRESS=0xEb421D07E885EeB2B8E9ea408FF284013F872Db1
GOVERNANCE_DAO_ADDRESS=0xd655d85ddACc386901487CE8E1ec45BD4F872A19
IMPACT_NFT_ADDRESS=0xF2556FcccaE36A6d8Da0C75a863CA7368FC6761a
# Set to deploy block for first sync; set 0 after backfill completes to skip re-scanning
DEPLOY_FROM_BLOCK=11146320
# Contract deploy block (floor when DEPLOY_FROM_BLOCK=0)
CONTRACT_DEPLOY_BLOCK=11146320
# When DEPLOY_FROM_BLOCK=0 and no persisted cursor, scan this many recent blocks for OrgVerified events
RECONCILE_ORG_LOOKBACK_BLOCKS=5000
# Org reconcile log scan tuning (separate from indexer backfill chunk size)
RECONCILE_ORG_CHUNK_SIZE=2000
RECONCILE_ORG_CHUNK_DELAY_MS=50
RECONCILE_ORG_PROGRESS_EVERY_CHUNKS=5
# Skip log scan when isOrgVerified synced all known orgs (set 0 to always scan logs)
RECONCILE_ORG_FAST_PATH=1
# Indexer tuning (Alchemy free tier: keep chunk size low)
INDEXER_LOG_CHUNK_SIZE=10
INDEXER_CHUNK_DELAY_MS=300
INDEXER_POLL_INTERVAL_MS=15000
PINATA_API_KEY=YOUR_PINATA_KEY
PINATA_SECRET_KEY=YOUR_PINATA_SECRET
CORS_ORIGIN=http://localhost:3000
